[Desktop Entry]
Version=1.0
Type=Application
Name=Android Emulator Selector
Exec=foot -e /absolute/path/to/script.py
Icon=android-studio
Comment=Script to open Android Emulator with any AVD you have.
Categories=Development;
Terminal=false
StartupNotify=true
# StartupWMClass=jetbrains-studio
MimeType=application/x-extension-iml;
